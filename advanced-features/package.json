{
  "name": "@nexus/advanced-features",
  "version": "1.0.0",
  "description": "Advanced features module for Nexus Cloud IDE Platform",
  "private": true,
  "workspaces": [
    "versionControl",
    "packageManagement",
    "aiCodeCompletion",
    "advancedDebugging",
    "performanceOptimization",
    "enterpriseFeatures",
    "extensionSystem",
    "aiAssistants"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint **/*.ts --ext .ts"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "moduleFileExtensions": [
      "ts",
      "js"
    ],
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "tsconfig": "./tsconfig.json"
        }
      ]
    },
    "collectCoverageFrom": [
      "**/src/**/*.ts",
      "!**/node_modules/**"
    ]
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.37",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  }
}
