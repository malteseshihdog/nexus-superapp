{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["./shared/src/*"]
    }
  },
  "include": ["tests/**/*.ts", "shared/src/**/*.ts", "pwa/src/**/*.ts"],
  "exclude": ["node_modules", "react-native/node_modules", "flutter"]
}
